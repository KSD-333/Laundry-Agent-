<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/notif_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_notif_card_unread"
    android:padding="16dp">

    <!-- Icon circle -->
    <FrameLayout
        android:id="@+id/notif_icon_bg"
        android:layout_width="48dp"
        android:layout_height="48dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <View
            android:id="@+id/notif_icon_circle"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_notif_icon_blue"/>
        <ImageView
            android:id="@+id/notif_icon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_bell"/>
    </FrameLayout>

    <!-- Unread dot -->
    <View
        android:id="@+id/unread_dot"
        android:layout_width="8dp"
        android:layout_height="8dp"
        android:background="@drawable/bg_notif_unread_dot"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <!-- Title -->
    <TextView
        android:id="@+id/notif_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_marginEnd="16dp"
        android:text="New Pickup Assigned"
        android:textColor="#0F172A"
        android:textSize="14sp"
        android:textStyle="bold"
        android:maxLines="1"
        android:ellipsize="end"
        app:layout_constraintStart_toEndOf="@id/notif_icon_bg"
        app:layout_constraintEnd_toStartOf="@id/unread_dot"
        app:layout_constraintTop_toTopOf="@id/notif_icon_bg"/>

    <!-- Message -->
    <TextView
        android:id="@+id/notif_message"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_marginTop="3dp"
        android:layout_marginEnd="16dp"
        android:text="Rahul Sharma — Amanora Park Town, 09:30 AM"
        android:textColor="#64748B"
        android:textSize="12sp"
        android:maxLines="2"
        android:ellipsize="end"
        app:layout_constraintStart_toEndOf="@id/notif_icon_bg"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/notif_title"/>

    <!-- Time -->
    <TextView
        android:id="@+id/notif_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_marginTop="6dp"
        android:text="2 min ago"
        android:textColor="#94A3B8"
        android:textSize="11sp"
        app:layout_constraintStart_toEndOf="@id/notif_icon_bg"
        app:layout_constraintTop_toBottomOf="@id/notif_message"/>

</androidx.constraintlayout.widget.ConstraintLayout>
