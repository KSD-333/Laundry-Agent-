<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    android:orientation="vertical">

    <!-- Top Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="20dp">
        
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Completed Deliveries"
            android:textColor="#0369A1"
            android:textSize="24sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Filter Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:layout_marginBottom="16dp">
        
        <TextView
            android:id="@+id/tv_current_filter"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="All Societies"
            android:textColor="#1E293B"
            android:textSize="16sp"
            android:textStyle="bold"/>
            
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Filter"
            app:icon="@android:drawable/ic_menu_sort_by_size"
            style="@style/Widget.Material3.Button.TonalButton"
            android:textColor="#0369A1"
            app:backgroundTint="#E0F2FE" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingHorizontal="20dp"
        android:clipToPadding="false">
        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Order 1 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_delivery_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:layout_marginHorizontal="4dp"
                app:cardBackgroundColor="@android:color/white"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp"
                android:outlineAmbientShadowColor="#10B981"
                android:outlineSpotShadowColor="#10B981">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Order #1982" android:textColor="#0369A1" android:textStyle="bold" android:textSize="16sp"/>
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:cardBackgroundColor="#D1FAE5"
                            app:cardCornerRadius="8dp"
                            app:cardElevation="0dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Delivered: 9:15 AM" android:textColor="#065F46" android:textSize="12sp" android:textStyle="bold" android:paddingHorizontal="8dp" android:paddingVertical="4dp"/>
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Vikas Joshi" android:textColor="#1E293B" android:textSize="18sp" android:textStyle="bold" android:layout_marginTop="12dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="C-201, Amanora Park Town, Pune" android:textColor="#64748B" android:textSize="14sp" android:layout_marginTop="4dp"/>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        app:cardBackgroundColor="#F0FDF4"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="#DCFCE7">
                        
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="8dp"
                            android:gravity="center_vertical">
                            
                            <ImageView 
                                android:layout_width="16dp" 
                                android:layout_height="16dp" 
                                android:src="@drawable/ic_user" 
                                app:tint="#166534" />
                            <TextView 
                                android:layout_width="wrap_content" 
                                android:layout_height="wrap_content" 
                                android:text="Agent: Raj Kumar" 
                                android:textColor="#166534" 
                                android:textSize="13sp" 
                                android:fontFamily="sans-serif-bold" 
                                android:layout_marginStart="8dp"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Order 2 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_delivery_2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:layout_marginHorizontal="4dp"
                app:cardBackgroundColor="@android:color/white"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp"
                android:outlineAmbientShadowColor="#10B981"
                android:outlineSpotShadowColor="#10B981">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Order #1980" android:textColor="#0369A1" android:textStyle="bold" android:textSize="16sp"/>
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:cardBackgroundColor="#D1FAE5"
                            app:cardCornerRadius="8dp"
                            app:cardElevation="0dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Delivered: Yesterday" android:textColor="#065F46" android:textSize="12sp" android:textStyle="bold" android:paddingHorizontal="8dp" android:paddingVertical="4dp"/>
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mrs. Mehta" android:textColor="#1E293B" android:textSize="18sp" android:textStyle="bold" android:layout_marginTop="12dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Villa 44, Magarpatta City, Pune" android:textColor="#64748B" android:textSize="14sp" android:layout_marginTop="4dp"/>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        app:cardBackgroundColor="#F0FDF4"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="#DCFCE7">
                        
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="8dp"
                            android:gravity="center_vertical">
                            
                            <ImageView 
                                android:layout_width="16dp" 
                                android:layout_height="16dp" 
                                android:src="@drawable/ic_user" 
                                app:tint="#166534" />
                            <TextView 
                                android:layout_width="wrap_content" 
                                android:layout_height="wrap_content" 
                                android:text="Agent: Amit Singh" 
                                android:textColor="#166534" 
                                android:textSize="13sp" 
                                android:fontFamily="sans-serif-bold" 
                                android:layout_marginStart="8dp"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
