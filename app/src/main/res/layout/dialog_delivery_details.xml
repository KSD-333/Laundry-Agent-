<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="16dp"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="28dp"
    app:cardElevation="12dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tv_delivery_order_id"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ORDER #1982"
                    android:textColor="#94A3B8"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="0.1" />
                <TextView
                    android:id="@+id/tv_delivery_user_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Vikas Joshi"
                    android:textColor="#0F172A"
                    android:textSize="20sp"
                    android:fontFamily="sans-serif-black"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                app:cardBackgroundColor="#D1FAE5"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DELIVERED"
                    android:textColor="#065F46"
                    android:textSize="10sp"
                    android:fontFamily="sans-serif-black"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="6dp" />
            </com.google.android.material.card.MaterialCardView>
        </RelativeLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="20dp"
            android:background="#F1F5F9" />

        <!-- Agent Info Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#F0FDF4"
            app:strokeWidth="1dp"
            app:strokeColor="#DCFCE7">
            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:gravity="center_vertical">
                
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp">
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/ic_user"
                        android:padding="10dp"
                        android:background="#BBF7D0"
                        app:tint="#166534" />
                </com.google.android.material.card.MaterialCardView>
                
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Delivery Agent"
                        android:textColor="#166534"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-black" />
                    <TextView
                        android:id="@+id/tv_delivery_agent_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Raj Kumar"
                        android:textColor="#14532D"
                        android:textSize="16sp"
                        android:fontFamily="sans-serif-bold" />
                </LinearLayout>

                <ImageButton
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_phone"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="#166534"
                    android:padding="10dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Amount & Payment -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="horizontal">
            
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total Amount"
                    android:textColor="#94A3B8"
                    android:textSize="12sp" />
                <TextView
                    android:id="@+id/tv_delivery_amount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹ 0.00"
                    android:textColor="#059669"
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-black"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Payment Method"
                    android:textColor="#94A3B8"
                    android:textSize="12sp" />
                <TextView
                    android:id="@+id/tv_delivery_payment"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Online (Paid)"
                    android:textColor="#1E293B"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Address & Dates -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="vertical"
            android:background="@drawable/bg_order_card"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="top">
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_pin"
                    app:tint="#64748B"
                    android:layout_marginTop="2dp" />
                <TextView
                    android:id="@+id/tv_delivery_address"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="User Complete Address"
                    android:textColor="#475569"
                    android:textSize="13sp" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F1F5F9" android:layout_marginVertical="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pickup Date"
                        android:textColor="#94A3B8"
                        android:textSize="11sp" />
                    <TextView
                        android:id="@+id/tv_delivery_pickup_date"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="May 12, 2024"
                        android:textColor="#1E293B"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Delivery Date"
                        android:textColor="#94A3B8"
                        android:textSize="11sp" />
                    <TextView
                        android:id="@+id/tv_delivery_complete_date"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="May 13, 2024"
                        android:textColor="#1E293B"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Bottom Action -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_delivery_dismiss"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="28dp"
            android:text="Close Details"
            style="@style/Widget.Material3.Button"
            app:backgroundTint="#0EA5E9"
            app:cornerRadius="16dp" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
