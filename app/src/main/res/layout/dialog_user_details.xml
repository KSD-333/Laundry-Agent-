<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="16dp"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="32dp"
    app:cardElevation="16dp"
    app:strokeWidth="0dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp"
        android:background="#FFFFFF">

        <!-- Header Profile -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_avatar_large"
            android:layout_width="80dp"
            android:layout_height="80dp"
            app:cardCornerRadius="40dp"
            app:cardElevation="4dp"
            app:strokeWidth="2dp"
            app:strokeColor="#E0F2FE"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/iv_dialog_user_avatar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_user"
                android:padding="20dp"
                android:background="#F0F9FF"
                app:tint="#0EA5E9" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tv_dialog_user_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:text="Rahul Sharma"
            android:textColor="#0F172A"
            android:textSize="22sp"
            android:fontFamily="sans-serif-black"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/card_avatar_large"
            app:layout_constraintTop_toTopOf="@id/card_avatar_large"
            app:layout_constraintBottom_toBottomOf="@id/card_avatar_large"/>

        <View
            android:id="@+id/divider1"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="24dp"
            android:background="#F1F5F9"
            app:layout_constraintTop_toBottomOf="@id/card_avatar_large" />

        <!-- Contact Info Section -->
        <TextView
            android:id="@+id/tv_label_contact"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Contact Information"
            android:textColor="#94A3B8"
            android:textSize="11sp"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            android:fontFamily="sans-serif-black"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/divider1" />

        <LinearLayout
            android:id="@+id/ll_contact_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            app:layout_constraintTop_toBottomOf="@id/tv_label_contact">

            <!-- Phone -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:gravity="center_vertical">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_phone"
                    app:tint="#64748B" />
                <TextView
                    android:id="@+id/tv_dialog_user_phone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="+91 98234 56789"
                    android:textColor="#1E293B"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

            <!-- Email -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:gravity="center_vertical">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_send"
                    android:rotation="-45"
                    app:tint="#64748B" />
                <TextView
                    android:id="@+id/tv_dialog_user_email"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="rahul.sharma@email.com"
                    android:textColor="#1E293B"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>
        </LinearLayout>

        <!-- Address Section -->
        <TextView
            android:id="@+id/tv_label_address"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Primary Address"
            android:textColor="#94A3B8"
            android:textSize="11sp"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            android:fontFamily="sans-serif-black"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/ll_contact_info" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_address"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#F8FAFC"
            app:strokeWidth="1dp"
            app:strokeColor="#F1F5F9"
            app:layout_constraintTop_toBottomOf="@id/tv_label_address">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:gravity="center_vertical">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_pin"
                    app:tint="#EF4444" />
                <TextView
                    android:id="@+id/tv_dialog_user_address"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="Flat 402, Sapphire Heights, Indore, MP 452001"
                    android:textColor="#475569"
                    android:textSize="14sp"
                    android:lineSpacingExtra="4dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Stats Section -->
        <LinearLayout
            android:id="@+id/ll_user_stats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/card_address">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:background="@drawable/bg_order_card"
                android:padding="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="12"
                    android:textColor="#1E293B"
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-black" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total Orders"
                    android:textColor="#94A3B8"
                    android:textSize="10sp" />
            </LinearLayout>

            <View android:layout_width="12dp" android:layout_height="match_parent" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:background="@drawable/bg_order_card"
                android:padding="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹ 4.2k"
                    android:textColor="#059669"
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-black" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Wallet Bal"
                    android:textColor="#94A3B8"
                    android:textSize="10sp" />
            </LinearLayout>
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_close_user_dialog"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="32dp"
            android:text="Dismiss"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:fontFamily="sans-serif-black"
            app:cornerRadius="16dp"
            app:backgroundTint="#0EA5E9"
            app:layout_constraintTop_toBottomOf="@id/ll_user_stats" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
