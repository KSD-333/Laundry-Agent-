<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Full-screen gradient background -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/gradient_login_bg"/>

    <!-- Decorative circles -->
    <View
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="-80dp"
        android:layout_marginEnd="-80dp"
        android:background="@drawable/bg_logo_ring"
        android:alpha="0.15"/>

    <View
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:layout_gravity="bottom|start"
        android:layout_marginBottom="-60dp"
        android:layout_marginStart="-60dp"
        android:background="@drawable/bg_logo_ring"
        android:alpha="0.12"/>

    <!-- Main scroll content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingTop="60dp"
            android:paddingBottom="40dp"
            android:paddingStart="24dp"
            android:paddingEnd="24dp">

            <!-- Logo ring + image -->
            <FrameLayout
                android:id="@+id/logo_card"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_marginBottom="8dp">
                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_logo_ring"/>
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="84dp"
                    android:layout_height="84dp"
                    android:layout_gravity="center"
                    app:cardCornerRadius="42dp"
                    app:cardElevation="8dp"
                    app:cardBackgroundColor="#FFFFFF">
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/app_logo"
                        android:scaleType="centerCrop"/>
                </com.google.android.material.card.MaterialCardView>
            </FrameLayout>

            <!-- App name -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LaundryAgent"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:textStyle="bold"
                android:letterSpacing="0.02"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Franchise Management Platform"
                android:textColor="#A8C4FF"
                android:textSize="13sp"
                android:layout_marginBottom="36dp"/>

            <!-- White card -->
            <LinearLayout
                android:id="@+id/login_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_login_card"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="28dp"
                android:paddingBottom="28dp">

                <!-- ── AGENT LOGIN ── -->
                <LinearLayout
                    android:id="@+id/agent_login_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_login_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Welcome back"
                        android:textColor="#0F172A"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Enter your mobile number to continue"
                        android:textColor="#64748B"
                        android:textSize="13sp"
                        android:layout_marginBottom="24dp"/>

                    <!-- Mobile field -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mobile Number"
                        android:textColor="#475569"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.04"
                        android:layout_marginBottom="8dp"/>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/mobile_layout"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:boxCornerRadiusBottomEnd="16dp"
                        app:boxCornerRadiusBottomStart="16dp"
                        app:boxCornerRadiusTopEnd="16dp"
                        app:boxCornerRadiusTopStart="16dp"
                        app:boxStrokeColor="#4361EE"
                        app:boxBackgroundColor="#F8F9FF"
                        app:hintEnabled="false"
                        app:startIconDrawable="@drawable/ic_phone"
                        app:startIconTint="#4361EE">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/mobile_input"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:hint="10-digit mobile number"
                            android:textColor="#1E293B"
                            android:textColorHint="#94A3B8"
                            android:textSize="15sp"
                            android:inputType="phone"
                            android:maxLength="10"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- OTP field (hidden initially) -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="One-Time Password"
                        android:textColor="#475569"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.04"
                        android:layout_marginTop="16dp"
                        android:layout_marginBottom="8dp"
                        android:visibility="gone"/>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/otp_layout"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:visibility="gone"
                        app:boxCornerRadiusBottomEnd="16dp"
                        app:boxCornerRadiusBottomStart="16dp"
                        app:boxCornerRadiusTopEnd="16dp"
                        app:boxCornerRadiusTopStart="16dp"
                        app:boxStrokeColor="#4361EE"
                        app:boxBackgroundColor="#F8F9FF"
                        app:hintEnabled="false"
                        app:startIconDrawable="@drawable/ic_otp"
                        app:startIconTint="#4361EE">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/otp_input"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:hint="Enter 6-digit OTP"
                            android:textColor="#1E293B"
                            android:textColorHint="#94A3B8"
                            android:textSize="15sp"
                            android:inputType="number"
                            android:maxLength="6"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Action button -->
                    <LinearLayout
                        android:id="@+id/btn_action"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="28dp"
                        android:background="@drawable/bg_login_btn"
                        android:gravity="center"
                        android:orientation="horizontal">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_send"
                            android:layout_marginEnd="10dp"/>
                        <TextView
                            android:id="@+id/btn_action_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Get OTP"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <!-- Resend OTP row (hidden until OTP is sent) -->
                    <LinearLayout
                        android:id="@+id/resend_otp_row"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Didn't receive OTP? "
                            android:textColor="#94A3B8"
                            android:textSize="13sp"/>

                        <TextView
                            android:id="@+id/btn_resend_otp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Resend in 30s"
                            android:textColor="#94A3B8"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:clickable="false"
                            android:focusable="false"/>
                    </LinearLayout>

                </LinearLayout>

                <!-- ── FRANCHISE LOGIN ── -->
                <LinearLayout
                    android:id="@+id/franchise_login_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Franchise Portal"
                        android:textColor="#0F172A"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sign in to your admin dashboard"
                        android:textColor="#64748B"
                        android:textSize="13sp"
                        android:layout_marginBottom="24dp"/>

                    <!-- Email -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Email Address"
                        android:textColor="#475569"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.04"
                        android:layout_marginBottom="8dp"/>

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:boxCornerRadiusBottomEnd="16dp"
                        app:boxCornerRadiusBottomStart="16dp"
                        app:boxCornerRadiusTopEnd="16dp"
                        app:boxCornerRadiusTopStart="16dp"
                        app:boxStrokeColor="#4361EE"
                        app:boxBackgroundColor="#F8F9FF"
                        app:hintEnabled="false"
                        app:startIconDrawable="@drawable/ic_user"
                        app:startIconTint="#4361EE">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/franchise_email"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:hint="admin@franchise.com"
                            android:textColor="#1E293B"
                            android:textColorHint="#94A3B8"
                            android:textSize="15sp"
                            android:inputType="textEmailAddress"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Password -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Password"
                        android:textColor="#475569"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.04"
                        android:layout_marginTop="16dp"
                        android:layout_marginBottom="8dp"/>

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:boxCornerRadiusBottomEnd="16dp"
                        app:boxCornerRadiusBottomStart="16dp"
                        app:boxCornerRadiusTopEnd="16dp"
                        app:boxCornerRadiusTopStart="16dp"
                        app:boxStrokeColor="#4361EE"
                        app:boxBackgroundColor="#F8F9FF"
                        app:hintEnabled="false"
                        app:passwordToggleEnabled="true"
                        app:startIconDrawable="@drawable/ic_otp"
                        app:startIconTint="#4361EE">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/franchise_password"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:hint="Enter your password"
                            android:textColor="#1E293B"
                            android:textColorHint="#94A3B8"
                            android:textSize="15sp"
                            android:inputType="textPassword"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Franchise login button -->
                    <LinearLayout
                        android:id="@+id/btn_franchise_login"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="28dp"
                        android:background="@drawable/bg_verify_btn"
                        android:gravity="center"
                        android:orientation="horizontal">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_otp"
                            android:layout_marginEnd="10dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Login as Franchise"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <!-- Support text -->
            <TextView
                android:id="@+id/tv_switch_login"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Trouble logging in? Contact Support"
                android:textColor="#A8C4FF"
                android:textSize="12sp"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</FrameLayout>
