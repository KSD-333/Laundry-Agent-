<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6FF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Gradient header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/gradient_header"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="36dp"
            android:paddingBottom="32dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp">

                <FrameLayout
                    android:id="@+id/btn_back"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent">
                    <View android:layout_width="match_parent" android:layout_height="match_parent" android:background="@drawable/bg_bell_button"/>
                    <ImageView android:layout_width="20dp" android:layout_height="20dp" android:layout_gravity="center" android:src="@drawable/ic_back"/>
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:orientation="vertical"
                    app:layout_constraintStart_toEndOf="@id/btn_back"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/btn_back"
                    app:layout_constraintBottom_toBottomOf="@id/btn_back">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Help Center" android:textColor="#FFFFFF" android:textSize="20sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Frequently asked questions" android:textColor="#A8C4FF" android:textSize="12sp"/>
                </LinearLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Support contact pill -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass_card"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp">
                <FrameLayout android:layout_width="40dp" android:layout_height="40dp" android:layout_marginEnd="14dp">
                    <View android:layout_width="match_parent" android:layout_height="match_parent" android:background="@drawable/bg_stat_icon_done"/>
                    <ImageView android:layout_width="20dp" android:layout_height="20dp" android:layout_gravity="center" android:src="@drawable/ic_phone"/>
                </FrameLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Support Helpline" android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Available 9 AM – 9 PM" android:textColor="#A8C4FF" android:textSize="12sp"/>
                </LinearLayout>
                <LinearLayout
                    android:id="@+id/btn_call_support"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_send_otp_btn"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Call Now" android:textColor="#FFFFFF" android:textSize="13sp" android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- White surface with FAQs -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_surface_rounded_top"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="28dp"
            android:paddingBottom="40dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="FAQ" android:textColor="#94A3B8" android:textSize="11sp" android:textStyle="bold" android:letterSpacing="0.1" android:layout_marginBottom="14dp"/>

            <!-- FAQ 1 -->
            <LinearLayout android:id="@+id/faq_1" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/bg_menu_row" android:orientation="vertical" android:layout_marginBottom="10dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="56dp" android:gravity="center_vertical" android:paddingStart="16dp" android:paddingEnd="16dp" android:orientation="horizontal">
                    <FrameLayout android:layout_width="32dp" android:layout_height="32dp" android:layout_marginEnd="12dp">
                        <View android:layout_width="match_parent" android:layout_height="match_parent" android:background="@drawable/bg_menu_icon_blue"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="1" android:textColor="#4361EE" android:textSize="12sp" android:textStyle="bold"/>
                    </FrameLayout>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="How do I mark a pickup as complete?" android:textColor="#0F172A" android:textSize="13sp" android:textStyle="bold"/>
                    <ImageView android:id="@+id/faq_1_arrow" android:layout_width="18dp" android:layout_height="18dp" android:src="@drawable/ic_chevron_right"/>
                </LinearLayout>
                <TextView android:id="@+id/faq_1_answer" android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingStart="60dp" android:paddingEnd="16dp" android:paddingBottom="14dp" android:text="After collecting all items from the customer, take at least one photo of the clothes, then tap the green 'Complete Pickup' button at the bottom of the Pickup Protocol screen." android:textColor="#64748B" android:textSize="13sp" android:lineSpacingExtra="3dp" android:visibility="gone"/>
            </LinearLayout>

            <!-- FAQ 2 -->
            <LinearLayout android:id="@+id/faq_2" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/bg_menu_row" android:orientation="vertical" android:layout_marginBottom="10dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="56dp" android:gravity="center_vertical" android:paddingStart="16dp" android:paddingEnd="16dp" android:orientation="horizontal">
                    <FrameLayout android:layout_width="32dp" android:layout_height="32dp" android:layout_marginEnd="12dp">
                        <View android:layout_width="match_parent" android:layout_height="match_parent" android:background="@drawable/bg_menu_icon_purple"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="2" android:textColor="#7209B7" android:textSize="12sp" android:textStyle="bold"/>
                    </FrameLayout>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="How does OTP verification work for delivery?" android:textColor="#0F172A" android:textSize="13sp" android:textStyle="bold"/>
                    <ImageView android:id="@+id/faq_2_arrow" android:layout_width="18dp" android:layout_height="18dp" android:src="@drawable/ic_chevron_right"/>
                </LinearLayout>
                <TextView android:id="@+id/faq_2_answer" android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingStart="60dp" android:paddingEnd="16dp" android:paddingBottom="14dp" android:text="On the Delivery Protocol screen, tap 'Send OTP'. A 4-digit code is sent to the customer's registered phone. Ask the customer for the code, enter it in the boxes, and tap 'Verify OTP &amp; Complete'." android:textColor="#64748B" android:textSize="13sp" android:lineSpacingExtra="3dp" android:visibility="gone"/>
            </LinearLayout>

            <!-- FAQ 3 -->
            <LinearLayout android:id="@+id/faq_3" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/bg_menu_row" android:orientation="vertical" android:layout_marginBottom="10dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="56dp" android:gravity="center_vertical" android:paddingStart="16dp" android:paddingEnd="16dp" android:orientation="horizontal">
                    <FrameLayout android:layout_width="32dp" android:layout_height="32dp" android:layout_marginEnd="12dp">
                        <View android:layout_width="match_parent" android:layout_height="match_parent" android:background="@drawable/bg_menu_icon_green"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="3" android:textColor="#06D6A0" android:textSize="12sp" android:textStyle="bold"/>
                    </FrameLayout>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="What should I do if a customer is not available?" android:textColor="#0F172A" android:textSize="13sp" android:textStyle="bold"/>
                    <ImageView android:id="@+id/faq_3_arrow" android:layout_width="18dp" android:layout_height="18dp" android:src="@drawable/ic_chevron_right"/>
                </LinearLayout>
                <TextView android:id="@+id/faq_3_answer" android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingStart="60dp" android:paddingEnd="16dp" android:paddingBottom="14dp" android:text="Call the customer using the phone button on the task card. If unreachable, tap 'Report Issue' and select 'Customer Not Available'. The task will be flagged for supervisor review." android:textColor="#64748B" android:textSize="13sp" android:lineSpacingExtra="3dp" android:visibility="gone"/>
            </LinearLayout>

            <!-- FAQ 4 -->
            <LinearLayout android:id="@+id/faq_4" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/bg_menu_row" android:orientation="vertical" android:layout_marginBottom="10dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="56dp" android:gravity="center_vertical" android:paddingStart="16dp" android:paddingEnd="16dp" android:orientation="horizontal">
                    <FrameLayout android:layout_width="32dp" android:layout_height="32dp" android:layout_marginEnd="12dp">
                        <View android:layout_width="match_parent" android:layout_height="match_parent" android:background="@drawable/bg_menu_icon_orange"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="4" android:textColor="#FF9F1C" android:textSize="12sp" android:textStyle="bold"/>
                    </FrameLayout>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="How do I report a damaged or stained item?" android:textColor="#0F172A" android:textSize="13sp" android:textStyle="bold"/>
                    <ImageView android:id="@+id/faq_4_arrow" android:layout_width="18dp" android:layout_height="18dp" android:src="@drawable/ic_chevron_right"/>
                </LinearLayout>
                <TextView android:id="@+id/faq_4_answer" android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingStart="60dp" android:paddingEnd="16dp" android:paddingBottom="14dp" android:text="On the Pickup Protocol screen, tap 'Report Issue' and choose the relevant option (e.g. Stain Present, Cloth Torn). Always photograph the damage before reporting so it is documented." android:textColor="#64748B" android:textSize="13sp" android:lineSpacingExtra="3dp" android:visibility="gone"/>
            </LinearLayout>

            <!-- FAQ 5 -->
            <LinearLayout android:id="@+id/faq_5" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/bg_menu_row" android:orientation="vertical" android:layout_marginBottom="10dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="56dp" android:gravity="center_vertical" android:paddingStart="16dp" android:paddingEnd="16dp" android:orientation="horizontal">
                    <FrameLayout android:layout_width="32dp" android:layout_height="32dp" android:layout_marginEnd="12dp">
                        <View android:layout_width="match_parent" android:layout_height="match_parent" android:background="@drawable/bg_menu_icon_blue"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="5" android:textColor="#4361EE" android:textSize="12sp" android:textStyle="bold"/>
                    </FrameLayout>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="How many photos can I take per order?" android:textColor="#0F172A" android:textSize="13sp" android:textStyle="bold"/>
                    <ImageView android:id="@+id/faq_5_arrow" android:layout_width="18dp" android:layout_height="18dp" android:src="@drawable/ic_chevron_right"/>
                </LinearLayout>
                <TextView android:id="@+id/faq_5_answer" android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingStart="60dp" android:paddingEnd="16dp" android:paddingBottom="14dp" android:text="You can capture up to 5 photos per order — Front, Back, Detail, and 2 extra slots. Tap any empty slot or the 'Take Photo' button. Tap a filled slot to retake that photo." android:textColor="#64748B" android:textSize="13sp" android:lineSpacingExtra="3dp" android:visibility="gone"/>
            </LinearLayout>

            <!-- FAQ 6 -->
            <LinearLayout android:id="@+id/faq_6" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/bg_menu_row" android:orientation="vertical" android:layout_marginBottom="28dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="56dp" android:gravity="center_vertical" android:paddingStart="16dp" android:paddingEnd="16dp" android:orientation="horizontal">
                    <FrameLayout android:layout_width="32dp" android:layout_height="32dp" android:layout_marginEnd="12dp">
                        <View android:layout_width="match_parent" android:layout_height="match_parent" android:background="@drawable/bg_menu_icon_purple"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="6" android:textColor="#7209B7" android:textSize="12sp" android:textStyle="bold"/>
                    </FrameLayout>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Why is a completed task greyed out?" android:textColor="#0F172A" android:textSize="13sp" android:textStyle="bold"/>
                    <ImageView android:id="@+id/faq_6_arrow" android:layout_width="18dp" android:layout_height="18dp" android:src="@drawable/ic_chevron_right"/>
                </LinearLayout>
                <TextView android:id="@+id/faq_6_answer" android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingStart="60dp" android:paddingEnd="16dp" android:paddingBottom="14dp" android:text="Completed tasks are shown in a muted style to help you focus on pending work. They cannot be reopened or modified. Contact your supervisor if a completed task needs correction." android:textColor="#64748B" android:textSize="13sp" android:lineSpacingExtra="3dp" android:visibility="gone"/>
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
