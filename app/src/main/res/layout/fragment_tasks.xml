<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6FF">

    <!-- ═══════════════════════════════════════════
         APP BAR  (scrolls away with content)
    ═══════════════════════════════════════════ -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_scrollFlags="scroll|enterAlways|snap">

            <!-- ─────────────────────────────────────
                 GRADIENT HEADER
            ───────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/gradient_header"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="32dp"
                android:paddingBottom="36dp">

                <!-- Row 1: Avatar · Name · Bell -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp">

                    <!-- Avatar -->
                    <FrameLayout
                        android:id="@+id/avatar_card"
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent">
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_avatar_circle" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="JD"
                            android:textColor="#FFFFFF"
                            android:textSize="17sp"
                            android:textStyle="bold" />
                    </FrameLayout>

                    <!-- Greeting + Name -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:orientation="vertical"
                        app:layout_constraintStart_toEndOf="@id/avatar_card"
                        app:layout_constraintEnd_toStartOf="@id/notification_card"
                        app:layout_constraintTop_toTopOf="@id/avatar_card"
                        app:layout_constraintBottom_toBottomOf="@id/avatar_card">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Good morning"
                            android:textColor="#A8C4FF"
                            android:textSize="12sp"
                            android:letterSpacing="0.05" />

                        <TextView
                            android:id="@+id/tv_agent_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Agent John"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.01" />
                    </LinearLayout>

                    <!-- Bell button -->
                    <FrameLayout
                        android:id="@+id/notification_card"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent">

                        <View
                            android:id="@+id/bell_btn"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_bell_button" />

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_bell" />

                        <!-- Red dot -->
                        <TextView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="top|end"
                            android:layout_marginTop="1dp"
                            android:layout_marginEnd="1dp"
                            android:background="@drawable/bg_notification_dot"
                            android:gravity="center"
                            android:text="9"
                            android:textColor="#FFFFFF"
                            android:textSize="9sp"
                            android:textStyle="bold" />
                    </FrameLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- Row 2: Stat Cards — compact -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Done -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_glass_card"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="12dp">

                        <FrameLayout
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:layout_marginEnd="10dp">
                            <View
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_stat_icon_done" />
                            <ImageView
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_check_circle" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <TextView
                                android:id="@+id/done_count"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="#FFFFFF"
                                android:textSize="22sp"
                                android:textStyle="bold" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Done"
                                android:textColor="#B8D4FF"
                                android:textSize="10sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Pending -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_glass_card"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="12dp">

                        <FrameLayout
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:layout_marginEnd="10dp">
                            <View
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_stat_icon_pending" />
                            <ImageView
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_clock" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <TextView
                                android:id="@+id/pending_count"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="#FFFFFF"
                                android:textSize="22sp"
                                android:textStyle="bold" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Pending"
                                android:textColor="#B8D4FF"
                                android:textSize="10sp" />
                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <!-- ─────────────────────────────────────
                 WHITE SURFACE  (rounded top)
            ───────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_surface_rounded_top"
                android:orientation="vertical"
                android:paddingTop="24dp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingBottom="0dp">

                <!-- Society Selector -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/society_dropdown_card"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginBottom="18dp"
                    android:background="@drawable/bg_society_selector"
                    android:paddingStart="16dp"
                    android:paddingEnd="12dp">

                    <ImageView
                        android:id="@+id/ic_pin_left"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_pin"
                        app:tint="#4361EE"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                    <TextView
                        android:id="@+id/society_text"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:text="All Societies"
                        android:textColor="#1E293B"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toEndOf="@id/ic_pin_left"
                        app:layout_constraintEnd_toStartOf="@id/map_location_button"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_marginEnd="10dp"
                        android:src="@drawable/ic_chevron_down"
                        app:layout_constraintEnd_toStartOf="@id/map_location_button"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                    <FrameLayout
                        android:id="@+id/map_location_button"
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent">
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_map_btn" />
                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_nav_map"
                            app:tint="#FFFFFF" />
                    </FrameLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- Pill Tab Bar -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginBottom="4dp"
                    android:background="@drawable/bg_tab_container">

                    <com.google.android.material.tabs.TabLayout
                        android:id="@+id/tab_layout"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@android:color/transparent"
                        app:tabBackground="@drawable/tab_selector_bg"
                        app:tabIndicatorHeight="0dp"
                        app:tabSelectedTextColor="#FFFFFF"
                        app:tabTextColor="#64748B"
                        app:tabTextAppearance="@style/PillTabText"
                        app:tabPaddingStart="6dp"
                        app:tabPaddingEnd="6dp"
                        app:tabMode="fixed"
                        app:tabGravity="fill">
                        <com.google.android.material.tabs.TabItem android:text="Pickup Tasks" />
                        <com.google.android.material.tabs.TabItem android:text="Delivery Tasks" />
                    </com.google.android.material.tabs.TabLayout>

                </FrameLayout>

            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- ═══════════════════════════════════════════
         CONTENT PAGER
    ═══════════════════════════════════════════ -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/tasks_view_pager"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
